---
interface Props {
  href?: string;
  class?: string;
}

const { href, class: className = '' } = Astro.props;

const baseClasses = 'rounded border p-6 hover:shadow-md hover:border-accent/30 transition-all duration-200';
---

{href ? (
  <a
    href={href}
    class:list={[baseClasses, 'block no-underline', className]}
  >
    <slot />
  </a>
) : (
  <div class:list={[baseClasses, className]}>
    <slot />
  </div>
)}
