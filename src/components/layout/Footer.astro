---
import { href } from '../../lib/constants';
const year = new Date().getFullYear();
---
<footer class="border-t border-gray-100 bg-[#f8f9fa]">
  <div class="mx-auto max-w-6xl px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12">
      <div>
        <a href={href('/')} class="font-serif text-xl text-[#212529] tracking-tight">
          <span class="font-semibold">NSIE</span><span class="font-normal text-gray-400">Team</span>
        </a>
        <p class="mt-3 text-sm text-gray-500 leading-relaxed max-w-sm">
          Sharing research, engineering insights, and technical notes from our team.
        </p>
      </div>

      <div>
        <h4 class="font-sans text-xs font-semibold tracking-widest text-gray-400 uppercase mb-4">Navigation</h4>
        <ul class="space-y-2.5">
          {[
            { label: 'Blog', href_: '/blog' },
            { label: 'About', href_: '/about' },
            { label: 'Submit a Post', href_: '/submit' },
          ].map((link) => (
            <li>
              <a href={href(link.href_)} class="text-sm text-gray-500 hover:text-[#b31b1b] transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-sans text-xs font-semibold tracking-widest text-gray-400 uppercase mb-4">Topics</h4>
        <ul class="space-y-2.5">
          {['Engineering', 'Research', 'Notes', 'News'].map((t) => (
            <li>
              <a href={href(`/topics/${t.toLowerCase()}`)} class="text-sm text-gray-500 hover:text-[#b31b1b] transition-colors capitalize">
                {t}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-200 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-gray-400">
      <p>&copy; {year} NSIETeam. Built with Astro.</p>
      <a
        href="https://github.com/nsieteam/nsieteam-blog"
        class="hover:text-[#b31b1b] transition-colors"
      >
        View on GitHub
      </a>
    </div>
  </div>
</footer>
