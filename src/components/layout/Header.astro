---
import { href } from '../../lib/constants';
---

<header class="sticky top-0 z-50 bg-[#1a1a2e]/95 backdrop-blur-md border-b border-white/5">
  <input type="checkbox" id="nav-toggle" class="peer sr-only" />

  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6 lg:px-8">
    <a
      href={href('/')}
      class="font-serif text-xl text-white tracking-tight hover:text-white/90 transition-colors"
    >
      <span class="font-semibold">NSIE</span><span class="font-normal text-white/60">Team</span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      <a
        href={href('/blog')}
        class="px-3 py-2 font-sans text-sm tracking-wide text-white/70 hover:text-white rounded-md hover:bg-white/5 transition-all"
      >
        Blog
      </a>

      <div class="group relative px-3 py-2">
        <span class="cursor-default font-sans text-sm tracking-wide text-white/70 group-hover:text-white transition-colors">
          Topics
          <svg class="inline-block w-3 h-3 ml-1 opacity-50 group-hover:opacity-80 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>
        </span>
        <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-1 group-hover:translate-y-0">
          <div class="w-44 rounded-xl border border-white/10 bg-[#1a1a2e]/98 backdrop-blur-xl px-2 py-2 shadow-2xl shadow-black/40">
            {['engineering', 'research', 'notes', 'news'].map((t) => (
              <a
                href={href(`/topics/${t}`)}
                class="block px-3 py-2 font-sans text-sm tracking-wide text-white/70 hover:text-white rounded-lg hover:bg-white/5 transition-all capitalize"
              >
                {t}
              </a>
            ))}
          </div>
        </div>
      </div>

      {['about', 'submit'].map((page) => (
        <a
          href={href(`/${page}`)}
          class="px-3 py-2 font-sans text-sm tracking-wide text-white/70 hover:text-white rounded-md hover:bg-white/5 transition-all capitalize"
        >
          {page === 'submit' ? 'Submit' : 'About'}
        </a>
      ))}
    </nav>

    <label for="nav-toggle" class="cursor-pointer md:hidden p-2 -mr-2 group" aria-label="Toggle navigation">
      <div class="flex flex-col gap-1">
        <span class="block h-px w-5 bg-white/60 group-hover:bg-white transition-colors"></span>
        <span class="block h-px w-5 bg-white/60 group-hover:bg-white transition-colors"></span>
        <span class="block h-px w-5 bg-white/60 group-hover:bg-white transition-colors"></span>
      </div>
    </label>
  </div>

  <nav class="hidden flex-col gap-1 bg-[#1a1a2e] px-6 pb-6 pt-2 peer-checked:flex md:hidden border-t border-white/5">
    <a href={href('/blog')} class="py-2 font-sans text-sm tracking-wide text-white/80">Blog</a>
    <span class="pt-2 pb-1 font-sans text-xs font-semibold tracking-widest text-white/30 uppercase">Topics</span>
    {['engineering', 'research', 'notes', 'news'].map((t) => (
      <a href={href(`/topics/${t}`)} class="pl-3 py-1.5 font-sans text-sm text-white/70 capitalize">{t}</a>
    ))}
    <a href={href('/about')} class="pt-2 pb-1.5 font-sans text-sm tracking-wide text-white/80">About</a>
    <a href={href('/submit')} class="py-1.5 font-sans text-sm tracking-wide text-white/80">Submit a Post</a>
  </nav>
</header>
