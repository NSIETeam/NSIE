---
import { getCollection } from 'astro:content';
import Container from '../components/ui/Container.astro';
import BlogCard from '../components/blog/BlogCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { href } from '../lib/constants';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredPosts = sortedPosts.slice(0, 3);
const postCount = sortedPosts.length;

const topics = [
  { name: 'Research', slug: 'research', description: 'Papers, studies, and experimental findings.', count: sortedPosts.filter(p => p.data.topic === 'research').length },
  { name: 'Engineering', slug: 'engineering', description: 'Software architecture, systems design, and implementation.', count: sortedPosts.filter(p => p.data.topic === 'engineering').length },
  { name: 'Notes', slug: 'notes', description: 'Quick technical notes, observations, and references.', count: sortedPosts.filter(p => p.data.topic === 'notes').length },
  { name: 'News', slug: 'news', description: 'Updates, announcements, and community highlights.', count: sortedPosts.filter(p => p.data.topic === 'news').length },
];
---

<BaseLayout title="NSIETeam Blog" description="Sharing research, engineering insights, and technical notes.">
  <!-- Hero -->
  <section class="relative pt-28 pb-16 md:pt-36 md:pb-20 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-white via-white to-[#f8f9fa] pointer-events-none" />
    <div class="relative mx-auto max-w-6xl px-6 lg:px-8">
      <div class="max-w-4xl">
        <div class="flex items-center gap-3 mb-6">
          <span class="h-px w-8 bg-[#b31b1b]" />
          <span class="font-sans text-xs font-semibold tracking-widest text-[#b31b1b] uppercase">
            Blog
          </span>
        </div>
        <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl tracking-tight text-[#212529] leading-[1.08] mb-6">
          NSIETeam
        </h1>
        <p class="text-lg md:text-xl text-gray-500 leading-relaxed max-w-xl">
          Sharing research, engineering insights, and technical notes from our team.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href={href('/blog')}
            class="inline-flex items-center px-5 py-2.5 bg-[#b31b1b] text-white font-sans text-sm font-medium rounded-lg hover:bg-[#8b0000] transition-all duration-200 shadow-sm shadow-[#b31b1b]/20 hover:shadow-md hover:shadow-[#b31b1b]/30"
          >
            Browse Posts
            <svg class="ml-2 w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </a>
          <a
            href={href('/submit')}
            class="inline-flex items-center px-5 py-2.5 border border-gray-200 text-gray-600 font-sans text-sm font-medium rounded-lg hover:border-gray-300 hover:text-gray-900 transition-all duration-200"
          >
            Submit a Post
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Posts -->
  {
    featuredPosts.length > 0 && (
      <section class="pb-16 md:pb-24">
        <div class="mx-auto max-w-6xl px-6 lg:px-8">
          <div class="flex items-end justify-between mb-10">
            <div>
              <h2 class="font-serif text-3xl md:text-4xl tracking-tight text-[#212529]">Featured Posts</h2>
              <p class="mt-1.5 text-sm text-gray-400">
                {postCount} {postCount === 1 ? 'article' : 'articles'} published
              </p>
            </div>
            <a
              href={href('/blog')}
              class="hidden sm:inline-flex items-center gap-1.5 font-sans text-sm text-[#b31b1b] hover:text-[#8b0000] transition-colors"
            >
              View all
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </a>
          </div>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {featuredPosts.map((post) => (
              <BlogCard post={post} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Topics Grid -->
  <section class="pb-24 md:pb-32 bg-[#f8f9fa]">
    <div class="mx-auto max-w-6xl px-6 lg:px-8">
      <div class="mb-10">
        <h2 class="font-serif text-3xl md:text-4xl tracking-tight text-[#212529]">Browse by Topic</h2>
        <p class="mt-1.5 text-sm text-gray-400">Explore articles organised by category.</p>
      </div>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {topics.map((topic) => (
          <a
            href={href(`/topics/${topic.slug}`)}
            class="group relative bg-white rounded-xl border border-gray-100 p-6 hover:border-[#b31b1b]/20 hover:shadow-lg hover:shadow-gray-200/50 transition-all duration-300"
          >
            <div class="flex items-center justify-between mb-4">
              <div class="w-10 h-10 rounded-lg bg-[#b31b1b]/5 flex items-center justify-center group-hover:bg-[#b31b1b]/10 transition-colors">
                <svg class="w-5 h-5 text-[#b31b1b]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  {topic.slug === 'research' && <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />}
                  {topic.slug === 'engineering' && <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />}
                  {topic.slug === 'notes' && <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />}
                  {topic.slug === 'news' && <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />}
                </svg>
              </div>
              <span class="font-sans text-xs font-semibold tracking-wider text-gray-300 group-hover:text-[#b31b1b] transition-colors">
                {topic.count} {topic.count === 1 ? 'post' : 'posts'}
              </span>
            </div>
            <h3 class="font-serif text-xl text-[#212529] mb-1.5">{topic.name}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{topic.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
