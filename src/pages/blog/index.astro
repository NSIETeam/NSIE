---
import { getCollection } from 'astro:content';
import Container from '../../components/ui/Container.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { href } from '../../lib/constants';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const postCount = sortedPosts.length;
const allTags = [...new Set(sortedPosts.flatMap(p => p.data.tags))];
---

<BaseLayout title="Blog" description="All posts from the NSIETeam Blog.">
  <section class="pt-28 pb-16 md:pt-36 md:pb-24">
    <div class="mx-auto max-w-6xl px-6 lg:px-8">
      <div class="max-w-4xl mb-12">
        <div class="flex items-center gap-3 mb-6">
          <span class="h-px w-8 bg-[#b31b1b]" />
          <span class="font-sans text-xs font-semibold tracking-widest text-[#b31b1b] uppercase">Blog</span>
        </div>
        <h1 class="font-serif text-4xl md:text-5xl tracking-tight text-[#212529] mb-4">
          All Posts
        </h1>
        <p class="text-gray-500 max-w-xl">
          {postCount} {postCount === 1 ? 'article' : 'articles'} across {allTags.length} {allTags.length === 1 ? 'tag' : 'tags'} and {[...new Set(sortedPosts.map(p => p.data.topic))].length} topics.
        </p>
      </div>

      {
        sortedPosts.length === 0 ? (
          <div class="text-center py-20">
            <p class="text-gray-400 text-lg">No posts have been published yet.</p>
            <p class="text-gray-300 text-sm mt-2">Check back soon for new content.</p>
          </div>
        ) : (
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {sortedPosts.map((post) => (
              <BlogCard post={post} />
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
